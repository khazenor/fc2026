	quest.652E92C4C78931C0.quest_desc: [
		"** Ren, o Pica-pau **"
		""
		"Você fez móveis muito bons... Deixe-me montar uma loja no assentamento... Eu ajudarei com marcenaria e ferraria."
	]
	quest.652E92C4C78931C0.title: "Mudança de Ren"
	quest.65BA9D1B2DCE2F7E.title: "Coletou 80 Floras Únicas!"
	quest.65C43C13CE6FF1F8.title: "Mudas de Bétula Concluídas"
	quest.65DCD492990110D3.title: "Comidas do Vinery Concluídas"
