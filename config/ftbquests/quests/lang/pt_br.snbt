	quest.6440EA925BDD070D.quest_desc: [
		"- Para começar a tirar fotos, clique com o botão direito com a câmera com papel no seu inventário"
		""
		"- depois disso, clique com o botão esquerdo para tirar uma foto"
		""
		"- role para dar zoom"
		""
		"- para colocar uma foto, segure shift e clique com o botão direito em uma parede"
		""
		"- segure shift e clique com o botão direito em uma foto para redimensionar e configurar (segure shift para encolher)"
		""
		"- segure shift e clique com o botão direito em um álbum para coletar fotos"
	]
	quest.6440EA925BDD070D.quest_subtitle: "Tirando Fotos com a Câmera"
