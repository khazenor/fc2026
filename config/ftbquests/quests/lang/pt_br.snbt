	quest.3849B0B4C3D81A24.title: "Comidas Vanilla Concluídas"
	quest.385BF7D960C48CEF.quest_desc: [
		"# Como obter folhas de chá de infusões de ervas:"
		"- cultive folhas de chá verde plantando flores de chá em terras aradas ou em vasos de botânica"
		"- fabrique um bloco de folhas de chá verde em uma bancada de trabalho"
		"- coloque o bloco de folhas de chá verde no chão e espere secar"
		"- quebre o bloco para obter folhas de chá verde depois que partículas verdes não forem mais emitidas do bloco de chá"
		"## chá preto"
		"- fabrique um bloco de folhas de chá verde secas a partir de folhas de chá verde"
		"- coloque o bloco no chão para secar até virar um bloco de folhas de chá preto"
		"## chá Oolong"
		"- fabrique um bloco de folhas de chá mistas usando folhas de chá verde e preto"
		"- coloque o bloco no chão para secar até virar um bloco de folhas de chá oolong"
	]
	quest.385BF7D960C48CEF.title: "Secando Chá"
	quest.387D9AE3BD7E53E6.title: "Convide Skye"
	quest.38DDF6DE6C1C57DE.title: "Melhoria de Vara de Pesca de Cristal"
	quest.39D526F16A1182EE.quest_desc: ["Agora que você coletou uma quantidade decente de flora. Você pode armazená-las em um caixote! Ele pode armazenar 640 itens, independentemente de quantos pacotes eram. Muito útil para muitos pacotes de poucos itens."]
	quest.39D526F16A1182EE.title: "Armazenamento em Caixote"
	quest.3AC5083E3D1BEDB0.quest_desc: [
		"** Ren, o Pica-pau **"
		""
		"Móveis feitos à mão podem ser decorados... Veja Rigg para almofadas e lençóis."
		""
		"== TUTORIAL DO MODPACK =="
		""
		"Almofadas e lençóis podem ser usados para decorar móveis feitos à mão (ex: lençóis podem ser colocados em mesas e almofadas podem ser colocadas em sofás)"
	]
	quest.3AC5083E3D1BEDB0.title: "Móveis Feitos à Mão"
