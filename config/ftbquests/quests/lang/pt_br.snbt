	quest.5D97E780E413EDAC.quest_desc: [
		"** Rigg, o Guaxinim **"
		""
		"Você precisa de uma maneira rápida de voltar para casa depois de um longo dia de exploração? Bem, não procure mais, pois acabei de encontrar algo enquanto viajava que pode resolver esse problema em um instante! Tudo pelo preço baixo, baixo de 16 tix!"
	]
