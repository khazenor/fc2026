	quest.5282566E7826B996.title: "Convide Matan"
	quest.5311686C2B4B0C71.quest_desc: [
		"** Laly, a Suricato **"
		""
		"Ooooh, você tem encontrado espécimes requintados! Eu ficaria emocionada em abrir uma nova filial do Museu de Oyster Creek no seu assentamento para exibir algumas joias locais!"
		""
		"== TUTORIAL DO MODPACK =="
		""
		"Colete 10 minerais únicos para a mudança de Laly"
	]
